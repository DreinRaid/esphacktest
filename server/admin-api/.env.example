# Server settings
PORT=3001

# Change this to a long random string
SESSION_SECRET=put-something-long-and-random-here

# Timeweb -> HTTPS/HTTP
# If your admin UI/API endpoint is served over HTTP (not HTTPS),
# set COOKIE_SECURE=false so cookies are actually accepted by the browser.
#
# COOKIE_SECURE=true  (default, for HTTPS)
# COOKIE_SECURE=false (for HTTP)
COOKIE_SECURE=false

# CORS: set to your GitHub Pages origin, for example:
# ADMIN_CORS_ORIGIN=https://teapot174.github.io
ADMIN_CORS_ORIGIN=https://YOUR_PAGES_ORIGIN

# What repo to edit
GH_OWNER=Teapot174
GH_REPO=esp-hack-wiki
GH_BRANCH=main

# GitHub token with write access to the wiki repository
GH_TOKEN=YOUR_GITHUB_TOKEN

# Allowed client login accounts (username -> password)
# Put it as JSON in an env var:
# ADMIN_USERS_JSON='{"you":"pass1","friend":"pass2"}'
ADMIN_USERS_JSON='{"you":"pass1","friend":"pass2"}'

# Optional: restrict editable paths
# ALLOWED_PATHS='["data/github-release.json","data/nav.json","data/nav-en.json","data/downloads.json"]'

